ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
API_KEY=your-team-api-key

# Directorio donde se crean los proyectos nuevos (Modo A)
PROJECTS_WORKSPACE=~/projects

# Azure DevOps — necesario para git push en repos existentes (Modo B y Multi)
AZURE_DEVOPS_PAT=your-pat-token
AZURE_DEVOPS_ORG=your-org

# LangSmith observability (opcional)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=backend-builder
